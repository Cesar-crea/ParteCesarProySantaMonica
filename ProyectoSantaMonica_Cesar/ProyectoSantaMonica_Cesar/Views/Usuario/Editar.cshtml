@model ProyectoSantaMonica_Cesar.Models.Usuario

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    body {
        background: #f4f7fb;
    }

    .card-form {
        width: 70%;
        margin: auto;
        margin-top: 50px;
        padding: 30px;
        background: white;
        border-radius: 16px;
    }

    .header {
        background: #5a9bd5;
        color: white;
        padding: 15px;
        border-radius: 12px;
        margin-bottom: 20px;
    }
</style>

<div class="card-form">
    <div class="header">
        <h4>Editar Usuario</h4>
    </div>

    <form asp-action="Actualizar" enctype="multipart/form-data">
        <input asp-for="Id_Usuario" type="hidden" />

        <input asp-for="Username" class="form-control mb-2" />
        <input asp-for="Contrasenia" type="password" class="form-control mb-2" placeholder="Nueva contraseña (opcional)" />
        <input asp-for="Nombres" class="form-control mb-2" />
        <input asp-for="Apellidos" class="form-control mb-2" />
        <input asp-for="Dni" class="form-control mb-2" />
        <input asp-for="Telefono" class="form-control mb-2" />
        <input asp-for="Correo" class="form-control mb-2" />

        <select asp-for="Rol" class="form-control mb-2">
            <option value="ADMINISTRADOR">ADMINISTRADOR</option>
            <option value="RECEPCIONISTA">RECEPCIONISTA</option>
            <option value="CAJERO">CAJERO</option>
        </select>

        <input type="file" name="archivoImagen" class="form-control mb-3" />

        <button class="btn btn-primary w-100">Actualizar</button>
    </form>
</div>

<script>
    var mensaje = '@TempData["Success"]';
    var error = '@TempData["Error"]';

    if (mensaje) {
        Swal.fire({ icon: 'success', title: mensaje });
    }
    if (error) {
        Swal.fire({ icon: 'error', title: error });
    }
</script>