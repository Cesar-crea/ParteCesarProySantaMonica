@model ProyectoSantaMonica_Cesar.Models.Especialidad

<div class="container mt-5">
    <div class="card p-4">
        <h2 class="text-primary">➕ Registrar Especialidad</h2>

        <form asp-action="Create" method="post" id="formCreate">

            <div class="mb-3">
                <label asp-for="Nombre"></label>
                <input asp-for="Nombre" class="form-control" required />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <button class="btn btn-primary mt-3">Guardar</button>
            <a asp-action="Index" class="btn btn-secondary mt-3">Cancelar</a>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    document.getElementById("formCreate").addEventListener("submit", function () {
        Swal.fire({
            icon: "success",
            title: "Especialidad registrada",
            showConfirmButton: false,
            timer: 1500
        });
    });
</script>