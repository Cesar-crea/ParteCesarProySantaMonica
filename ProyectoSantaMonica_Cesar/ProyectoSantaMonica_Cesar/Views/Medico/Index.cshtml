@model IEnumerable<ProyectoSantaMonica_Cesar.Models.Medico>

@{
    ViewData["Title"] = "Listado de Médicos";
}

<!-- Bootstrap & otros -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    body {
        background-color: #f4f7fb;
        font-family: 'Poppins', sans-serif;
    }

    .card {
        border-radius: 16px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
        margin: 50px auto;
        max-width: 1100px;
    }

    .card-header {
        background-color: #007bff;
        color: white;
        padding: 20px;
        border-radius: 16px 16px 0 0;
    }

    .table thead {
        background-color: #eaf2ff;
        color: #0056b3;
    }

    .btn-edit {
        background-color: #5a9bd5;
        color: white;
    }

    .btn-danger {
        background-color: #e63946;
    }

    table {
        white-space: nowrap;
    }
</style>

<div class="container">
    <div class="card">
        <div class="card-header">
            <h4><i class="bi bi-person-vcard me-2"></i>Listado de Médicos</h4>
        </div>

        <div class="card-body">
            <div class="text-end mb-3">
                <a asp-action="Create" class="btn btn-success">
                    <i class="bi bi-plus-circle"></i> Nuevo Médico
                </a>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered text-center table-responsive">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nombres</th>
                            <th>Apellidos</th>
                            <th>DNI</th>
                            <th>Colegiatura</th>
                            <th>Teléfono</th>
                            <th>Especialidad</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="8">No hay médicos registrados</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var m in Model)
                            {
                                <tr>
                                    <td>@m.Id_Medico</td>
                                    <td>@m.Nombres</td>
                                    <td>@m.Apellidos</td>
                                    <td>@m.Dni</td>
                                    <td>@m.Nro_Colegiatura</td>
                                    <td>@m.Telefono</td>
                                    <td>@m.Especialidad</td>
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@m.Id_Medico" class="btn btn-edit btn-sm">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <a asp-action="Delete" class="btn btn-danger btn-sm"
                                                asp-route-id="@m.Id_Medico">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            
        </div>
    </div>
</div>


<!-- SweetAlert mensajes -->
@if (TempData["Success"] != null)
{
    <script>
        Swal.fire({
            icon: 'success',
            title: '@TempData["Success"]',
            showConfirmButton: false,
            timer: 1500
        });
    </script>
}
