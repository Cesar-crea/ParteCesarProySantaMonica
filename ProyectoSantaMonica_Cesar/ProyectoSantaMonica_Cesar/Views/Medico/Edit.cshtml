@model ProyectoSantaMonica_Cesar.Models.Medico

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    .card-form {
        width: 70%;
        margin: auto;
        margin-top: 50px;
        padding: 30px;
        background: white;
        border-radius: 16px;
    }

    .header {
        background: #5a9bd5;
        color: white;
        padding: 15px;
        border-radius: 12px;
        margin-bottom: 20px;
    }
</style>

<div class="card-form">
    <div class="header">
        <h4>Editar Médico</h4>
    </div>

    <form asp-action="Edit">
        <input asp-for="Id_Medico" type="hidden" />

        <input asp-for="Nombres" class="form-control" />
        <br />
        <input asp-for="Apellidos" class="form-control" />
        <br />
        <input asp-for="Dni" class="form-control" />
        <br />
        <input asp-for="Nro_Colegiatura" class="form-control" />
        <br />
        <input asp-for="Telefono" class="form-control" />
        <br />

        <select asp-for="Id_Especialidad" asp-items="ViewBag.Especialidades" class="form-select">
       
        </select>

        <br />

        <button class="btn btn-primary">Actualizar</button>
        <a asp-action="Index" class="btn btn-secondary">Volver</a>
    </form>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

