@model IEnumerable<ProyectoSantaMonica_Cesar.Models.Paciente>

@{
    ViewData["Title"] = "Pacientes";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Pacientes</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: #f4f6f9;
        }

        .card-custom {
            border-radius: 12px;
            box-shadow: 0 5px 12px rgba(0,0,0,0.1);
        }
    </style>
</head>

<body>

    <div class="container mt-5">
        <div class="card card-custom p-4">

            <h2 class="text-primary">🧑‍⚕️ Pacientes</h2>

            <a asp-action="Create" class="btn btn-success mb-3">+ Nuevo Paciente</a>

            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nombres</th>
                        <th>Apellidos</th>
                        <th>DNI</th>
                        <th>Fecha Nac.</th>
                        <th>Teléfono</th>
                        <th>Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id_Paciente</td>
                            <td>@item.Nombres</td>
                            <td>@item.Apellidos</td>
                            <td>@item.Dni</td>
                            <td>@item.Fecha_Nacimiento?.ToString("dd/MM/yyyy")</td>
                            <td>@item.Telefono</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id_Paciente" class="btn btn-warning btn-sm">✏</a>
                                <a asp-action="Details" asp-route-id="@item.Id_Paciente" class="btn btn-info btn-sm">👁</a>
                                <a asp-action="Delete" asp-route-id="@item.Id_Paciente" class="btn btn-danger btn-sm">🗑</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (TempData["Success"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: '@TempData["Success"]',
                showConfirmButton: false,
                timer: 1500
            });
        </script>
    }

</body>
</html>